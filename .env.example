# Variables de entorno para /api/reservar (envío de correo de reservas)
# Copiá este archivo como .env.local para desarrollo, y cargá los mismos valores
# en Vercel → Project → Settings → Environment Variables.

# Resend (envío de correos) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Upstash Redis (contador correlativo de reservas) — https://upstash.com
# También podés crearlo desde Vercel → Storage → KV (usa Upstash por detrás).
UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcionales (tienen defaults en el código)
# RESERVAS_TO=hamerfelipe7@gmail.com
# RESERVAS_FROM=PARRILLA EL TORO <onboarding@resend.dev>
